direction: right

title: |md
  # beads-skills ecosystem
  Install groups + `depends-on-skill` edges (arrow = "depends on")
| {
  near: top-center
  style.font-size: 26
}

beads: "beads group — needs the bd binary" {
  style.fill: "#eef4fb"
  style.stroke: "#2f6fb0"

  bdplan: "yf-plan\n[bd, uv, git]"
  bdresearch: "yf-research\n[bd, uv, git]"
  incub: "yf-incubator\n[uv]"
  bupstream: "yf-beads-upstream\n[bd, uv, gh]"
  bauthor: "yf-beads-authoring\n[bd]"
  bextra: "yf-beads-extra\n[bd]"
}

util: "utility group — beads-free (no bd)" {
  style.fill: "#eef7ee"
  style.stroke: "#3f8f4f"

  skauth: "yf-skill-authoring\n[uv]"
  optinst: "yf-optimal-instructions\n[uv]"
  drift: "yf-drift-check\n[ ]"
  diagram: "yf-diagram-authoring\n[d2]"
}

# depends-on-skill edges (the install set closes over these)
beads.bdplan -> beads.bextra
beads.bdplan -> beads.bauthor
beads.bdresearch -> beads.bextra
beads.bdresearch -> beads.bauthor
beads.bauthor -> beads.bextra
beads.bupstream -> beads.bextra
beads.incub -> beads.bextra
util.optinst -> util.skauth

invariant: |md
  **Invariant:** no `utility` skill may depend
  (transitively) on a `beads` skill — that keeps
  `--group utility` provably beads-free.
| {
  near: bottom-center
  style.font-size: 13
  style.fill: "#fffbe6"
  style.stroke: "#c9a227"
}
