__pycache__/
*.pyc

# Rust / Cargo build artifacts (yf workspace)
/target/

# Skill runtime state + local config (never committed; per Skill Surface Convention)
/.state/
/.bdplan.local.json
/.agent-shell/

/.worktrees/
